# ADK Router local development environment variables.
# Copy to .env and fill in your values. Never commit .env to git.

# ── Required ──────────────────────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# ── Go Service URLs (docker-compose networking) ───────────────────────────────
CORTEX_GRPC_URL=localhost:50051
THALAMUS_GRPC_URL=localhost:50052
MASTERY_GRPC_URL=localhost:50053
RESEARCHER_GRPC_URL=localhost:50054
CURRICULUM_GRPC_URL=localhost:50055
INTEGRATIONS_GRPC_URL=localhost:50056
ENTITY_GRPC_URL=localhost:50057

# ── GCP Pub/Sub ───────────────────────────────────────────────────────────────
PUBSUB_INPUT_SUBSCRIPTION=adk-router-voice-input
PUBSUB_ROUTING_LOG_TOPIC=wisdom.router.decision_logged

# ── Vertex AI ─────────────────────────────────────────────────────────────────
ROUTER_MODEL=gemini-2.0-flash
EXPERT_MODEL=gemini-2.5-pro
MEMORY_BANK_CORPUS=wisdom-memory-bank
MEMORY_BANK_TOP_K=5

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8081
LOG_LEVEL=INFO
DEFAULT_USER_ID=default
